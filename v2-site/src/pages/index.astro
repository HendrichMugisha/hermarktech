        <div class="flex items-center justify-center gap-3 mb-4">
            <img src="/hermark_logo.png" alt="Hermark Tech" class="h-6 object-contain opacity-70 grayscale" onerror="this.style.display='none'" />
            <span class="text-sm font-bold tracking-[0.15em] text-slate-500 font-headline uppercase">Hermark</span>
        </div>
        <p class="text-[9px] tracking-[0.2em] text-slate-600 uppercase font-bold">© 2026 HERMARK TECH SOLUTIONS. ALL RIGHTS RESERVED.</p>
    </footer>

    <style>
        @keyframes marquee {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }
    </style>

    <script>
        // Initialize Vanta.js NET Background
        window.addEventListener('DOMContentLoaded', () => {
            if (window.VANTA) {
                window.VANTA.NET({
                    el: "#hero-bg",
                    mouseControls: true,
                    touchControls: true,
                    gyroControls: false,
                    minHeight: 200.00,
                    minWidth: 200.00,
                    scale: 1.00,
                    scaleMobile: 1.00,
                    color: 0x007a87,
                    backgroundColor: 0x010a0c,
                    points: 12.00,
                    maxDistance: 22.00,
                    spacing: 18.00
                })
            }
        });

        // Auto-Scrolling Carousel Logic
        const carousel = document.getElementById('projectCarousel');
        let isHovered = false;
        let isTouching = false;
        let scrollSpeed = 0.5;

        if (carousel) {
            carousel.addEventListener('mouseenter', () => isHovered = true);
            carousel.addEventListener('mouseleave', () => isHovered = false);
            carousel.addEventListener('touchstart', () => isTouching = true);
            carousel.addEventListener('touchend', () => { setTimeout(() => isTouching = false, 1500); });

            function autoScroll() {
                if (!isHovered && !isTouching) {
                    carousel.scrollLeft += scrollSpeed;
                    if (carousel.scrollLeft >= (carousel.scrollWidth / 2)) {
                        carousel.scrollLeft = 0;
                    }
                }
                requestAnimationFrame(autoScroll);
            }
            setTimeout(() => { requestAnimationFrame(autoScroll); }, 1000);
        }

        // Mobile Menu Logic
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const closeMenuBtn = document.getElementById('closeMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        if (mobileMenuBtn && closeMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.remove('hidden');
                mobileMenu.classList.add('flex');
            });
            closeMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
                mobileMenu.classList.remove('flex');
            });
            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                });
            });
        }
    </script>
</Layout>
