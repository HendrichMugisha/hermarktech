---
import Layout from '../layouts/Layout.astro';

const coreProjects = [
  {
    name: "Estra AI Diagnostic",
    description: "Precision biological mapping and reproductive cycle optimization using 30-day hormonal digital twins.",
    impact: "Achieved precision 30-day biological mapping with 99.9% uptime.",
    tech: ["React", "Python AI", "Node.js"],
    link: "https://estra-ai.com",
    image: "/estra.png"
  },
  {
    name: "Aura Executives Base",
    description: "Premier executive ushering infrastructure with VIP protocol handlers and real-time floor logistics management.",
    impact: "Zero-downtime VIP logistics management across premium enterprise floors.",
    tech: ["Next.js", "Postgres", "Tailwind"],
    link: "http://auraexecutives.com/",
    image: "/aura.png"
  },
  {
    name: "The Cooking Nurse",
    description: "Automated e-commerce, digital product delivery, and DRM-protected premium online course streaming.",
    impact: "Automated delivery for 1,000+ premium digital course streaming hours.",
    tech: ["React", "Node.js", "VdoCipher DRM"],
    link: "https://the-cooking-nurse-repo.onrender.com/",
    image: "/the_cooking_nurse.png"
  },
  {
    name: "Material Girl UG",
    description: "Bespoke enterprise retail POS engine with zero-collision QR generation and multi-branch live inventory tracking.",
    impact: "Scaled to handle 10,000+ zero-collision QR scans with multi-branch sync.",
    tech: ["Next.js", "Hardware Auth", "Role-Based Access"],
    link: "https://materialgirlug-inventory.onrender.com/",
    image: "/material.png"
  }
];

// Duplicate projects to create a seamless infinite scrolling effect
const projects = [...coreProjects, ...coreProjects];

const techStack = [
    "React", "Next.js", "Node.js", "PostgreSQL", "Python AI", "Tailwind CSS", "AWS", "Astro", "TypeScript", "Vercel"
];
---

<Layout title="Hermark Tech Solutions | Bespoke Engineering">
    <!-- NAVIGATION -->
    <header class="fixed top-0 w-full z-50 transition-all duration-500 bg-[#010A0C]/90 backdrop-blur-md border-b border-white/5 flex justify-between items-center px-6 lg:px-12 py-4 shadow-md">
        <div class="flex items-center gap-3">
            <img src="/hermark_logo.png" alt="Hermark Tech" class="h-8 md:h-10 object-contain" onerror="this.style.display='none'" />
            <span class="text-lg md:text-xl font-bold tracking-[0.15em] text-white font-headline uppercase">Hermark</span>
        </div>
        
        <nav class="hidden md:flex gap-8 items-center">
            <a class="text-xs font-bold tracking-widest uppercase text-white/70 hover:text-brand-yellow transition-colors" href="#philosophy">Our Approach</a>
            <a class="text-xs font-bold tracking-widest uppercase text-white/70 hover:text-brand-yellow transition-colors" href="#work">Portfolio</a>
            <a class="bg-gradient-to-r from-brand-teal to-brand-yellow text-brand-dark px-6 py-2.5 rounded-full text-xs font-bold tracking-widest uppercase hover:scale-105 transition-transform shadow-lg" href="#contact">Discuss Your Vision</a>
        </nav>

        <button id="mobileMenuBtn" class="md:hidden text-white p-2">
            <span class="material-symbols-outlined text-3xl">menu</span>
        </button>
    </header>

    <!-- Mobile Dropdown Menu -->
    <div id="mobileMenu" class="fixed inset-0 bg-[#010A0C] z-40 hidden flex-col items-center justify-center gap-8 pt-16">
        <button id="closeMenuBtn" class="absolute top-6 right-6 text-white p-2">
            <span class="material-symbols-outlined text-3xl">close</span>
        </button>
        <a class="mobile-link text-xl font-bold tracking-widest uppercase text-white hover:text-brand-yellow transition-colors" href="#philosophy">Our Approach</a>
        <a class="mobile-link text-xl font-bold tracking-widest uppercase text-white hover:text-brand-yellow transition-colors" href="#work">Portfolio</a>
        <a class="mobile-link bg-gradient-to-r from-brand-teal to-brand-yellow text-brand-dark px-8 py-4 rounded-full text-lg font-bold tracking-widest uppercase hover:scale-105 transition-transform shadow-lg mt-4" href="#contact">Discuss Your Vision</a>
    </div>

    <!-- PREMIUM HERO (Dark with vibrant Teal Glow to match Navbar) -->
    <section class="relative min-h-[90vh] flex items-center justify-center pt-32 pb-24 overflow-hidden bg-[#010A0C]">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-teal/40 via-[#010A0C] to-[#010A0C] opacity-100 -z-10"></div>
        
        <div class="relative z-10 text-center px-6 max-w-5xl mx-auto space-y-8 mt-12 md:mt-0">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-brand-teal/30 bg-brand-teal/10 backdrop-blur-sm">
                <span class="w-2 h-2 rounded-full bg-brand-yellow animate-pulse"></span>
                <span class="text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-brand-yellow font-bold">Bespoke Engineering Agency</span>
            </div>

            <h1 class="text-4xl sm:text-5xl md:text-7xl font-headline font-bold text-white leading-[1.1] tracking-tight">
                We Engineer Bespoke <br class="hidden md:block"/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-teal to-brand-yellow">Digital Solutions.</span>
            </h1>

            <p class="text-base md:text-xl text-white/80 max-w-3xl mx-auto font-light leading-relaxed">
                No generic templates. We listen to your business bottlenecks and architect custom software that drives growth, automates operations, and scales seamlessly.
            </p>

            <div class="pt-6">
                <a class="inline-flex items-center gap-3 px-8 py-4 md:px-10 md:py-5 bg-gradient-to-r from-brand-teal to-brand-yellow text-brand-dark rounded-full font-bold tracking-widest uppercase hover:scale-105 transition-transform duration-300 shadow-[0_0_30px_rgba(0,122,135,0.4)] text-xs md:text-sm" href="#contact">
                    Discuss Your Vision
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
        </div>
        
        <!-- Curved bottom divider -->
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20">
            <svg class="relative block w-full h-[30px] md:h-[50px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V0C73.41,26.63,149.33,39.69,228.64,48.24,259.94,51.62,291.5,54.7,321.39,56.44Z" class="fill-white"></path>
            </svg>
        </div>
    </section>

    <!-- TECH STACK MARQUEE (Social Proof) -->
    <div class="bg-white py-6 border-b border-slate-100 overflow-hidden relative">
        <div class="absolute left-0 top-0 w-16 h-full bg-gradient-to-r from-white to-transparent z-10"></div>
        <div class="absolute right-0 top-0 w-16 h-full bg-gradient-to-l from-white to-transparent z-10"></div>
        <div class="flex items-center whitespace-nowrap animate-[marquee_20s_linear_infinite]">
            <!-- Double the array for seamless loop -->
            {[...techStack, ...techStack].map((tech) => (
                <span class="mx-8 text-xs font-bold tracking-[0.2em] uppercase text-slate-300">{tech}</span>
            ))}
        </div>
    </div>

    <!-- PHILOSOPHY / HOW WE WORK -->
    <section class="py-20 md:py-28 relative z-10 bg-white" id="philosophy">
        <div class="max-w-7xl mx-auto px-6 md:px-12 text-center">
            <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold mb-4">Our Philosophy</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight mb-16">How We Transform Businesses</h3>
            
            <div class="grid md:grid-cols-4 gap-12 md:gap-6 text-left">
                <!-- Step 1 -->
                <div class="space-y-4">
                    <span class="text-4xl font-bold text-slate-200 block mb-2">01</span>
                    <h4 class="text-xl font-bold text-brand-dark font-headline">Discovery</h4>
                    <p class="text-slate-600 text-sm leading-relaxed">We sit down with you to understand your exact business workflow, bottlenecks, and grand vision. We listen first.</p>
                </div>
                <!-- Step 2 -->
                <div class="space-y-4">
                    <span class="text-4xl font-bold text-slate-200 block mb-2">02</span>
                    <h4 class="text-xl font-bold text-brand-dark font-headline">Architecture</h4>
                    <p class="text-slate-600 text-sm leading-relaxed">We design and code a custom digital infrastructure tailored perfectly to your needs. Nothing is off-the-shelf.</p>
                </div>
                <!-- Step 3 -->
                <div class="space-y-4">
                    <span class="text-4xl font-bold text-brand-teal block mb-2">03</span>
                    <h4 class="text-xl font-bold text-brand-dark font-headline">Deployment</h4>
                    <p class="text-slate-600 text-sm leading-relaxed">We launch the solution, integrate it seamlessly into your current operations, and train your entire team.</p>
                </div>
                <!-- Step 4 -->
                <div class="space-y-4">
                    <span class="text-4xl font-bold text-brand-yellow block mb-2">04</span>
                    <h4 class="text-xl font-bold text-brand-dark font-headline">Continuous Dev</h4>
                    <p class="text-slate-600 text-sm leading-relaxed">We don't just launch and leave. We provide ongoing maintenance, scaling, and feature iteration as your business grows.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- HORIZONTAL CAROUSEL PORTFOLIO (With Hard ROI) -->
    <section class="py-20 md:py-28 relative z-10 bg-slate-50 border-y border-slate-200" id="work">
        <div class="max-w-7xl mx-auto px-6 md:px-12 mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="space-y-4">
                <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold">Proof of Work</h2>
                <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight">Our Portfolio</h3>
            </div>
            <p class="text-slate-600 max-w-sm text-sm leading-relaxed">
                Explore our recent enterprise-grade builds. We focus on engineering solutions that deliver measurable ROI.
            </p>
        </div>

        <div class="max-w-[100vw] overflow-hidden relative">
            <div class="absolute top-0 left-0 w-16 md:w-32 h-full bg-gradient-to-r from-slate-50 to-transparent z-20 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-16 md:w-32 h-full bg-gradient-to-l from-slate-50 to-transparent z-20 pointer-events-none"></div>

            <div id="projectCarousel" class="flex overflow-x-auto hide-scrollbar gap-6 md:gap-8 px-6 md:px-12 pb-12 items-stretch cursor-grab active:cursor-grabbing">
                {projects.map((project, index) => (
                    <div class="min-w-[85vw] md:min-w-[45vw] lg:min-w-[30vw] group relative h-auto flex" onclick={`window.open('${project.link}', '_blank')`}>
                        
                        <!-- Gradient Border Wrapper -->
                        <div class="p-[2px] rounded-[1.25rem] bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-[1.02] transition-transform duration-300">
                            
                            <div class="bg-white rounded-[1.1rem] overflow-hidden shadow-sm h-full flex flex-col">
                                <div class="aspect-[16/10] overflow-hidden bg-slate-100 relative">
                                    <img src={project.image} alt={project.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" onerror="this.src='https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&q=80&w=1200'" />
                                </div>
                                
                                <div class="p-6 md:p-8 flex-grow flex flex-col">
                                    <h4 class="text-xl md:text-2xl font-headline font-bold text-brand-dark mb-3 group-hover:text-brand-teal transition-colors">{project.name}</h4>
                                    
                                    <!-- Hard ROI Badge -->
                                    <div class="bg-brand-yellow/10 border border-brand-yellow/30 text-brand-dark text-[11px] font-bold px-3 py-2 rounded-lg mb-4 flex items-start gap-2">
                                        <span class="material-symbols-outlined text-brand-yellow text-[14px]">trending_up</span>
                                        <span>{project.impact}</span>
                                    </div>

                                    <p class="text-slate-600 text-xs md:text-sm leading-relaxed mb-6 flex-grow">{project.description}</p>
                                    
                                    <div class="flex flex-wrap gap-2 mt-auto">
                                        {project.tech.map(tech => (
                                            <span class="text-[8px] md:text-[9px] tracking-widest text-slate-500 font-bold uppercase bg-slate-100 px-3 py-1.5 rounded-full border border-slate-200">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- LEADERSHIP / THE AGENCY FACE -->
    <section class="py-20 md:py-28 relative z-10 bg-white">
        <div class="max-w-5xl mx-auto px-6 text-center">
            <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold mb-4">The Leadership</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight mb-16">Meet the Architects</h3>
            
            <div class="grid md:grid-cols-2 gap-8 text-left">
                <!-- Charlene -->
                <div class="bg-slate-50 border border-slate-200 p-8 rounded-3xl flex flex-col items-center text-center">
                    <div class="w-24 h-24 bg-gradient-to-br from-brand-teal to-brand-yellow rounded-full mb-6 p-[3px] shadow-lg">
                        <div class="w-full h-full bg-white rounded-full flex items-center justify-center overflow-hidden">
                            <span class="text-3xl font-bold text-brand-teal font-headline">CN</span>
                        </div>
                    </div>
                    <h4 class="text-2xl font-bold text-brand-dark font-headline mb-1">Charlene Nyakaisiki</h4>
                    <p class="text-xs tracking-[0.2em] text-brand-teal uppercase font-bold mb-4">Founder & Visionary</p>
                    <p class="text-slate-600 text-sm leading-relaxed">Spearheading the strategic direction and ensuring every solution aligns perfectly with our clients' long-term business goals.</p>
                </div>
                
                <!-- Henry -->
                <div class="bg-slate-50 border border-slate-200 p-8 rounded-3xl flex flex-col items-center text-center">
                    <div class="w-24 h-24 bg-gradient-to-br from-brand-teal to-brand-yellow rounded-full mb-6 p-[3px] shadow-lg">
                        <div class="w-full h-full bg-white rounded-full flex items-center justify-center overflow-hidden">
                            <span class="text-3xl font-bold text-brand-teal font-headline">HT</span>
                        </div>
                    </div>
                    <h4 class="text-2xl font-bold text-brand-dark font-headline mb-1">Henry Mark Tukamwesiga</h4>
                    <p class="text-xs tracking-[0.2em] text-brand-teal uppercase font-bold mb-4">CTO & Lead Architect</p>
                    <p class="text-slate-600 text-sm leading-relaxed">Directing the engineering team and architecting highly scalable, zero-downtime infrastructure for enterprise operations.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- REFINED CONTACT / LEAD GEN SECTION -->
    <section class="py-20 md:py-28 relative z-10 bg-[#010A0C]" id="contact">
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_bottom,_var(--tw-gradient-stops))] from-brand-teal to-transparent -z-10"></div>
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-xs tracking-[0.3em] text-brand-yellow uppercase font-bold mb-4">Start Your Transformation</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-white font-bold tracking-tight mb-10">Let's Build Together</h3>
            
            <div class="grid md:grid-cols-2 gap-6 mb-12">
                <!-- Soft CTA -->
                <div class="bg-white/5 border border-white/10 p-8 rounded-3xl text-left backdrop-blur-sm flex flex-col">
                    <h4 class="text-xl font-bold text-white mb-2">Technical Audit</h4>
                    <p class="text-slate-400 text-sm mb-8 flex-grow">Not ready to build? Book a free 15-minute consultation to audit your current infrastructure.</p>
                    <button class="w-full bg-white/10 border border-white/20 text-white py-4 rounded-xl font-bold uppercase hover:bg-white/20 transition-colors text-xs tracking-widest mt-auto">
                        Book via Calendly
                    </button>
                </div>

                <!-- Hard CTA -->
                <div class="bg-white p-8 rounded-3xl text-left shadow-2xl relative overflow-hidden border border-brand-teal/20 flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-brand-teal to-brand-yellow"></div>
                    <h4 class="text-xl font-bold text-brand-dark mb-2">Direct Line</h4>
                    <p class="text-slate-600 text-sm mb-8 flex-grow">Ready to scale? Skip the email chains. Connect directly with our Lead Architect right now.</p>
                    <button onclick="window.open('https://wa.me/256750432982?text=Hi%2C%20I%20would%20like%20to%20discuss%20a%20custom%20software%20project.', '_blank')" class="w-full bg-gradient-to-r from-brand-teal to-brand-yellow text-brand-dark py-4 rounded-xl font-bold uppercase hover:scale-105 transition-transform text-xs tracking-widest shadow-lg flex justify-center items-center gap-2 mt-auto">
                        <span class="material-symbols-outlined text-[18px]">chat</span>
                        WhatsApp Us
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#010A0C] py-12 text-center px-6 border-t-[4px] border-brand-teal/30">
        <div class="flex items-center justify-center gap-3 mb-6">
            <img src="/hermark_logo.png" alt="Hermark Tech" class="h-6 object-contain opacity-70 grayscale" onerror="this.style.display='none'" />
            <span class="text-sm font-bold tracking-[0.15em] text-slate-500 font-headline uppercase">Hermark</span>
        </div>
        <p class="text-[9px] tracking-[0.2em] text-slate-600 uppercase font-bold">© 2026 HERMARK TECH SOLUTIONS. ALL RIGHTS RESERVED.</p>
    </footer>

    <style>
        @keyframes marquee {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }
    </style>

    <script>
        // Auto-Scrolling Carousel Logic
        const carousel = document.getElementById('projectCarousel');
        let isHovered = false;
        let isTouching = false;
        let scrollSpeed = 0.5;

        if (carousel) {
            carousel.addEventListener('mouseenter', () => isHovered = true);
            carousel.addEventListener('mouseleave', () => isHovered = false);
            carousel.addEventListener('touchstart', () => isTouching = true);
            carousel.addEventListener('touchend', () => { setTimeout(() => isTouching = false, 1500); });

            function autoScroll() {
                if (!isHovered && !isTouching) {
                    carousel.scrollLeft += scrollSpeed;
                    
                    if (carousel.scrollLeft >= (carousel.scrollWidth / 2)) {
                        carousel.scrollLeft = 0;
                    }
                }
                requestAnimationFrame(autoScroll);
            }
            
            setTimeout(() => {
                requestAnimationFrame(autoScroll);
            }, 1000);
        }

        // Mobile Menu Logic
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const closeMenuBtn = document.getElementById('closeMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        if (mobileMenuBtn && closeMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.remove('hidden');
                mobileMenu.classList.add('flex');
            });

            closeMenuBtn.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
                mobileMenu.classList.remove('flex');
            });

            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('flex');
                });
            });
        }
    </script>
</Layout>
