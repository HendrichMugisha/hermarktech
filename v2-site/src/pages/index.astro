---
import Layout from '../layouts/Layout.astro';

const coreProjects = [
  {
    name: "Estra AI Diagnostic",
    description: "Precision biological mapping and reproductive cycle optimization using 30-day hormonal digital twins.",
    impact: "Achieved precision 30-day biological mapping with 99.9% uptime.",
    tech: ["React", "Python AI", "Node.js"],
    link: "https://estra-ai.com",
    image: "/estra.png"
  },
  {
    name: "Aura Executives Base",
    description: "Premier executive ushering infrastructure with VIP protocol handlers and real-time floor logistics management.",
    impact: "Zero-downtime VIP logistics management across premium enterprise floors.",
    tech: ["Next.js", "Postgres", "Tailwind"],
    link: "http://auraexecutives.com/",
    image: "/aura.png"
  },
  {
    name: "Vélour Éclair Apparel",
    description: "High-fashion avant-garde streetwear architecture featuring an immersive 3-level interactive lookbook and live multi-tag catalog filtering.",
    impact: "Showcase prototype demonstrating premium dark-mode editorial UI/UX.",
    tech: ["HTML5", "Vanilla JS", "Tailwind CSS"],
    link: "https://mockups.hermarktech.com/clothing_store_site/",
    image: "/mockup_clothing.avif"
  },
  {
    name: "The Grand Serenade Hotel",
    description: "Ultra-luxury eco-resort application equipped with an interactive satellite map explorer, before/after spa slider, and live quotation engine.",
    impact: "Showcase prototype demonstrating elite hospitality digital transformation.",
    tech: ["HTML5", "Vanilla JS", "Tailwind CSS"],
    link: "https://mockups.hermarktech.com/hotel_site/",
    image: "/mockup_hotel.png"
  },
  {
    name: "Aura Botanica Cosmetics",
    description: "Advanced luxury skincare architecture featuring an interactive Clinical Consultation Routine Finder, dynamic Science Matrix, and shopping bag state.",
    impact: "Showcase prototype demonstrating premium cosmetic commerce funnels.",
    tech: ["HTML5", "Vanilla JS", "Tailwind CSS"],
    link: "https://mockups.hermarktech.com/beauty_store_site/",
    image: "/mockup_beauty.png"
  },
  {
    name: "Veritas International Academy",
    description: "Classical heritage meets neo-brutalist tech infrastructure. Showcases an interactive Academic Pathfinder Quiz and Admissions Eligibility Checker.",
    impact: "Showcase prototype demonstrating elite preparatory institution portals.",
    tech: ["HTML5", "Vanilla JS", "Tailwind CSS"],
    link: "https://mockups.hermarktech.com/school_site/",
    image: "/mockup_school.png"
  }
];

const projects = [...coreProjects, ...coreProjects];

const techStack = [
    "React", "Next.js", "Node.js", "PostgreSQL", "Python AI", "Tailwind CSS", "AWS", "Astro", "TypeScript", "Vercel"
];
---

<Layout title="Hermark Tech Solutions | Bespoke Engineering">
    <!-- NAVIGATION -->
    <header class="fixed top-0 w-full z-50 transition-all duration-500 bg-[#010A0C]/80 backdrop-blur-md border-b border-white/5 flex justify-between items-center px-6 lg:px-12 py-4 shadow-md">
        <div class="flex items-center gap-3">
            <img src="/hermark_logo.png" alt="Hermark Tech" class="h-8 md:h-10 object-contain" onerror="this.style.display='none'" />
            <span class="text-lg md:text-xl font-bold tracking-[0.15em] text-white font-headline uppercase">Hermark</span>
        </div>
        
        <nav class="hidden md:flex gap-8 items-center">
            <a class="text-xs font-bold tracking-widest uppercase text-white/70 hover:text-brand-yellow transition-colors" href="#philosophy">Our Approach</a>
            <a class="text-xs font-bold tracking-widest uppercase text-white/70 hover:text-brand-yellow transition-colors" href="#work">Portfolio</a>
            
            <div class="p-[2px] rounded-full bg-gradient-to-r from-brand-teal to-brand-yellow inline-block hover:scale-105 transition-transform shadow-[0_0_15px_rgba(255,215,0,0.2)]">
                <a class="block bg-[#010A0C] text-white px-6 py-2.5 rounded-full text-xs font-bold tracking-widest uppercase" href="#contact">Discuss Your Vision</a>
            </div>
        </nav>

        <button id="mobileMenuBtn" class="md:hidden text-white p-2">
            <span class="material-symbols-outlined text-3xl">menu</span>
        </button>
    </header>

    <!-- Mobile Dropdown Menu -->
    <div id="mobileMenu" class="fixed inset-0 bg-[#010A0C] z-40 hidden flex-col items-center justify-center gap-8 pt-16">
        <button id="closeMenuBtn" class="absolute top-6 right-6 text-white p-2">
            <span class="material-symbols-outlined text-3xl">close</span>
        </button>
        <a class="mobile-link text-xl font-bold tracking-widest uppercase text-white hover:text-brand-yellow transition-colors" href="#philosophy">Our Approach</a>
        <a class="mobile-link text-xl font-bold tracking-widest uppercase text-white hover:text-brand-yellow transition-colors" href="#work">Portfolio</a>
        <div class="p-[2px] rounded-full bg-gradient-to-r from-brand-teal to-brand-yellow mt-4">
            <a class="mobile-link block bg-[#010A0C] text-white px-8 py-4 rounded-full text-lg font-bold tracking-widest uppercase" href="#contact">Discuss Your Vision</a>
        </div>
    </div>

    <!-- PREMIUM HERO (Vanta.js NET Background) -->
    <section id="hero-bg" class="relative min-h-[90vh] flex items-center justify-center pt-32 pb-20 overflow-hidden bg-[#010A0C]">
        <div class="absolute inset-0 bg-gradient-to-b from-[#010A0C]/50 via-transparent to-[#010A0C] z-0 pointer-events-none"></div>
        
        <div class="relative z-10 text-center px-6 max-w-5xl mx-auto space-y-8 mt-12 md:mt-0">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-brand-teal/50 bg-[#010A0C]/50 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-brand-yellow animate-pulse"></span>
                <span class="text-[9px] md:text-[10px] tracking-[0.2em] uppercase text-brand-yellow font-bold">Bespoke Engineering Agency</span>
            </div>

            <h1 class="text-4xl sm:text-5xl md:text-7xl font-headline font-bold text-white leading-[1.1] tracking-tight">
                We Engineer The Software <br class="hidden md:block"/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-teal to-brand-yellow drop-shadow-lg">Your Business Needs.</span>
            </h1>

            <p class="text-base md:text-xl text-white/90 max-w-3xl mx-auto font-light leading-relaxed backdrop-blur-sm bg-black/20 p-2 rounded-lg">
                Stop relying on generic templates. Tell us your exact operational bottlenecks, and we will architect custom digital solutions that automate your workflow and scale your revenue.
            </p>

            <div class="pt-6 flex flex-col sm:flex-row items-center justify-center gap-6">
                <!-- Primary CTA: Let's Discuss Your Project -->
                <div class="p-[3px] rounded-full bg-gradient-to-r from-brand-teal to-brand-yellow inline-block shadow-[0_0_20px_rgba(255,215,0,0.5)] animate-[pulse_3s_infinite] hover:scale-105 transition-transform duration-300 w-full sm:w-auto">
                    <a class="flex items-center justify-center gap-3 bg-[#010A0C] hover:bg-brand-dark transition-colors text-white px-8 py-4 md:px-10 md:py-5 rounded-full font-bold tracking-widest uppercase text-xs md:text-sm" href="#contact">
                        Let's Discuss Your Project
                        <span class="material-symbols-outlined text-sm text-brand-yellow">arrow_forward</span>
                    </a>
                </div>
                <!-- Secondary CTA: Explore Industry Prototypes -->
                <div class="w-full sm:w-auto hover:scale-105 transition-transform duration-300">
                    <a class="flex items-center justify-center gap-3 bg-white/10 hover:bg-white/20 border border-white/20 backdrop-blur-md text-white px-8 py-4 md:px-10 md:py-5 rounded-full font-bold tracking-widest uppercase text-xs md:text-sm shadow-xl" href="https://mockups.hermarktech.com/" target="_blank">
                        Inspect Industry Prototypes
                        <span class="material-symbols-outlined text-sm text-brand-teal">open_in_new</span>
                    </a>
                </div>
            </div>
        </div>
        
        <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-20">
            <svg class="relative block w-full h-[30px] md:h-[50px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
                <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V0C73.41,26.63,149.33,39.69,228.64,48.24,259.94,51.62,291.5,54.7,321.39,56.44Z" class="fill-white"></path>
            </svg>
        </div>
    </section>

    <!-- TECH STACK MARQUEE -->
    <div class="bg-white py-8 border-b border-slate-100 overflow-hidden relative">
        <div class="absolute left-0 top-0 w-16 h-full bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 w-16 h-full bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
        <div class="flex items-center whitespace-nowrap animate-[marquee_25s_linear_infinite]">
            {[...techStack, ...techStack].map((tech) => (
                <div class="mx-4 bg-slate-50 border border-slate-200 shadow-sm px-6 py-3 rounded-full flex items-center justify-center">
                    <span class="text-xs font-bold tracking-[0.15em] uppercase text-brand-teal">{tech}</span>
                </div>
            ))}
        </div>
    </div>

    <!-- PHILOSOPHY / HOW WE WORK (Light, Vibrant, Enterprise) -->
    <section class="py-16 md:py-24 relative z-10 bg-slate-50 overflow-hidden" id="philosophy">
        <!-- Dim Scattered Graphics Background -->
        <span class="material-symbols-outlined absolute top-[10%] left-[5%] text-[12rem] text-brand-teal/5 -rotate-12 pointer-events-none z-0">schema</span>
        <span class="material-symbols-outlined absolute bottom-[20%] right-[5%] text-[15rem] text-brand-yellow/5 rotate-12 pointer-events-none z-0">memory</span>
        <span class="material-symbols-outlined absolute top-[40%] right-[30%] text-[8rem] text-brand-dark/5 rotate-45 pointer-events-none z-0">data_object</span>

        <div class="max-w-7xl mx-auto px-6 md:px-12 text-center relative z-10">
            <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold mb-4">Our Methodology</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight mb-16">How We Transform Your Business</h3>
            
            <div class="flex flex-col md:flex-row justify-center items-stretch gap-2 md:gap-4 lg:gap-4">
                <!-- Step 1 -->
                <div class="w-full md:w-1/4 group relative">
                    <div class="p-[2px] rounded-3xl bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-105 transition-transform duration-300 shadow-lg">
                        <div class="bg-white rounded-[1.4rem] p-8 h-full flex flex-col items-center text-center">
                            <div class="w-16 h-16 bg-brand-teal/10 rounded-full flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined text-brand-teal text-3xl">psychology</span>
                            </div>
                            <h4 class="text-xl font-bold text-brand-dark font-headline mb-3">You Tell Us</h4>
                            <p class="text-slate-600 text-sm leading-relaxed">You break down your exact operational bottlenecks, inefficiencies, and your grand vision for scaling.</p>
                        </div>
                    </div>
                </div>

                <!-- Animated Arrow (Vibrant) -->
                <div class="flex items-center justify-center py-4 md:py-0 text-brand-yellow">
                    <span class="material-symbols-outlined text-4xl rotate-90 md:rotate-0 animate-[pulse_2s_infinite]">arrow_right_alt</span>
                </div>

                <!-- Step 2 -->
                <div class="w-full md:w-1/4 group relative">
                    <div class="p-[2px] rounded-3xl bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-105 transition-transform duration-300 shadow-lg">
                        <div class="bg-white rounded-[1.4rem] p-8 h-full flex flex-col items-center text-center">
                            <div class="w-16 h-16 bg-brand-teal/10 rounded-full flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined text-brand-teal text-3xl">architecture</span>
                            </div>
                            <h4 class="text-xl font-bold text-brand-dark font-headline mb-3">We Architect</h4>
                            <p class="text-slate-600 text-sm leading-relaxed">We engineer a bespoke digital infrastructure perfectly tailored to solve those exact problems.</p>
                        </div>
                    </div>
                </div>

                <!-- Animated Arrow (Vibrant) -->
                <div class="flex items-center justify-center py-4 md:py-0 text-brand-yellow">
                    <span class="material-symbols-outlined text-4xl rotate-90 md:rotate-0 animate-[pulse_2s_infinite]">arrow_right_alt</span>
                </div>

                <!-- Step 3 -->
                <div class="w-full md:w-1/4 group relative">
                    <div class="p-[2px] rounded-3xl bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-105 transition-transform duration-300 shadow-lg">
                        <div class="bg-white rounded-[1.4rem] p-8 h-full flex flex-col items-center text-center">
                            <div class="w-16 h-16 bg-brand-teal/10 rounded-full flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined text-brand-teal text-3xl">rocket_launch</span>
                            </div>
                            <h4 class="text-xl font-bold text-brand-dark font-headline mb-3">Deployment</h4>
                            <p class="text-slate-600 text-sm leading-relaxed">We launch the software, seamlessly integrate it into your workflow, and personally train your team.</p>
                        </div>
                    </div>
                </div>

                <!-- Animated Arrow (Vibrant) -->
                <div class="flex items-center justify-center py-4 md:py-0 text-brand-yellow">
                    <span class="material-symbols-outlined text-4xl rotate-90 md:rotate-0 animate-[pulse_2s_infinite]">arrow_right_alt</span>
                </div>

                <!-- Step 4 -->
                <div class="w-full md:w-1/4 group relative">
                    <div class="p-[2px] rounded-3xl bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-105 transition-transform duration-300 shadow-lg">
                        <div class="bg-white rounded-[1.4rem] p-8 h-full flex flex-col items-center text-center">
                            <div class="w-16 h-16 bg-brand-yellow/10 rounded-full flex items-center justify-center mb-6">
                                <span class="material-symbols-outlined text-brand-yellow text-3xl">update</span>
                            </div>
                            <h4 class="text-xl font-bold text-brand-dark font-headline mb-3">Evolution</h4>
                            <p class="text-slate-600 text-sm leading-relaxed">We don't launch and leave. We maintain, iterate, and continuously scale the software as you grow.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- HORIZONTAL CAROUSEL PORTFOLIO -->
    <section class="py-16 md:py-24 relative z-10 bg-white border-y border-slate-200" id="work">
        <div class="max-w-7xl mx-auto px-6 md:px-12 mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="space-y-4">
                <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold">Proof of Work</h2>
                <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight">Our Portfolio</h3>
            </div>
            <p class="text-slate-600 max-w-sm text-sm leading-relaxed">
                Explore our recent enterprise-grade builds. We focus on engineering solutions that deliver measurable ROI.
            </p>
        </div>

        <div class="max-w-[100vw] overflow-hidden relative">
            <div class="absolute top-0 left-0 w-16 md:w-32 h-full bg-gradient-to-r from-white to-transparent z-20 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-16 md:w-32 h-full bg-gradient-to-l from-white to-transparent z-20 pointer-events-none"></div>

            <div id="projectCarousel" class="flex overflow-x-auto hide-scrollbar gap-6 md:gap-8 px-6 md:px-12 pb-12 items-stretch cursor-grab active:cursor-grabbing">
                {projects.map((project, index) => (
                    <div class="min-w-[85vw] md:min-w-[45vw] lg:min-w-[30vw] group relative flex" onclick={`window.open('${project.link}', '_blank')`}>
                        <div class="p-[2px] rounded-[1.25rem] bg-gradient-to-br from-brand-teal via-slate-200 to-brand-yellow w-full h-full hover:scale-[1.02] transition-transform duration-300 shadow-md">
                            <div class="bg-white rounded-[1.1rem] overflow-hidden h-full flex flex-col">
                                <div class="h-48 md:h-64 overflow-hidden bg-slate-100 relative shrink-0">
                                    <img src={project.image} alt={project.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" onerror="this.src='https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&q=80&w=1200'" />
                                </div>
                                <div class="p-6 md:p-8 flex-grow flex flex-col">
                                    <h4 class="text-xl md:text-2xl font-headline font-bold text-brand-dark mb-2 group-hover:text-brand-teal transition-colors">{project.name}</h4>
                                    <div class="bg-brand-yellow/10 border border-brand-yellow/30 text-brand-dark text-[11px] font-bold px-3 py-2 rounded-lg mb-4 flex items-start gap-2 shrink-0">
                                        <span class="material-symbols-outlined text-brand-yellow text-[14px]">trending_up</span>
                                        <span>{project.impact}</span>
                                    </div>
                                    <p class="text-slate-600 text-xs md:text-sm leading-relaxed mb-6 flex-grow">{project.description}</p>
                                    <div class="flex flex-wrap gap-2 mt-auto shrink-0">
                                        {project.tech.map(tech => (
                                            <span class="text-[8px] md:text-[9px] tracking-widest text-brand-teal font-bold uppercase bg-brand-teal/5 px-3 py-1.5 rounded-full border border-brand-teal/20">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- LEADERSHIP / THE AGENCY FACE -->
    <section class="py-16 md:py-24 relative z-10 bg-slate-50">
        <div class="max-w-5xl mx-auto px-6 text-center">
            <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold mb-4">The Leadership</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight mb-12">Meet the Architects</h3>
            
            <div class="grid md:grid-cols-2 gap-8 text-left">
                <!-- Charlene -->
                <div class="bg-white border border-slate-200 p-8 rounded-3xl flex flex-col items-center text-center hover:shadow-xl transition-shadow shadow-md">
                    <div class="w-32 h-32 bg-gradient-to-br from-brand-teal to-brand-yellow rounded-full mb-6 p-[4px] shadow-xl hover:scale-105 transition-transform duration-300">
                        <div class="w-full h-full bg-[#010A0C] rounded-full overflow-hidden border-2 border-[#010A0C] relative">
                            <img src="/charlene.png" alt="Charlene Nyakaisiki" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'><rect width=\'100\' height=\'100\' fill=\'%23010A0C\'/><text x=\'50\' y=\'55\' font-family=\'Arial\' font-size=\'30\' fill=\'%23007a87\' font-weight=\'bold\' text-anchor=\'middle\' alignment-baseline=\'middle\'>CN</text></svg>'" />
                        </div>
                    </div>
                    <h4 class="text-2xl font-bold text-brand-dark font-headline mb-1">Charlene Nyakaisiki</h4>
                    <p class="text-xs tracking-[0.2em] text-brand-teal uppercase font-bold mb-4">Founder & Visionary</p>
                    <p class="text-slate-600 text-sm leading-relaxed">Spearheading the strategic direction and ensuring every solution aligns perfectly with our clients' long-term business goals.</p>
                </div>
                
                <!-- Henry -->
                <div class="bg-white border border-slate-200 p-8 rounded-3xl flex flex-col items-center text-center hover:shadow-xl transition-shadow shadow-md">
                    <div class="w-32 h-32 bg-gradient-to-br from-brand-teal to-brand-yellow rounded-full mb-6 p-[4px] shadow-xl hover:scale-105 transition-transform duration-300">
                        <div class="w-full h-full bg-[#010A0C] rounded-full overflow-hidden border-2 border-[#010A0C] relative">
                            <img src="/henry.png" alt="Henry Mark Tukamwesiga" class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'><rect width=\'100\' height=\'100\' fill=\'%23010A0C\'/><text x=\'50\' y=\'55\' font-family=\'Arial\' font-size=\'30\' fill=\'%23007a87\' font-weight=\'bold\' text-anchor=\'middle\' alignment-baseline=\'middle\'>HT</text></svg>'" />
                        </div>
                    </div>
                    <h4 class="text-2xl font-bold text-brand-dark font-headline mb-1">Henry Mark Tukamwesiga</h4>
                    <p class="text-xs tracking-[0.2em] text-brand-teal uppercase font-bold mb-4">CTO & Lead Architect</p>
                    <p class="text-slate-600 text-sm leading-relaxed">Directing the engineering team and architecting highly scalable, zero-downtime infrastructure for enterprise operations.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- REFINED CONTACT / LEAD GEN SECTION (Light & Vibrant Theme) -->
    <section class="py-16 md:py-24 relative z-10 bg-white overflow-hidden" id="contact">
        <!-- Dim Scattered Graphics for Light Background -->
        <span class="material-symbols-outlined absolute top-[20%] left-[10%] text-[10rem] text-brand-teal/5 rotate-45 pointer-events-none z-0">terminal</span>
        <span class="material-symbols-outlined absolute bottom-[10%] right-[5%] text-[14rem] text-brand-yellow/5 -rotate-12 pointer-events-none z-0">all_inclusive</span>

        <div class="max-w-5xl mx-auto px-6 text-center relative z-10">
            <h2 class="text-xs tracking-[0.3em] text-brand-teal uppercase font-bold mb-4">Start Your Transformation</h2>
            <h3 class="font-headline text-3xl md:text-5xl text-brand-dark font-bold tracking-tight mb-10">Let's Build Something Great</h3>
            
            <div class="grid md:grid-cols-2 gap-6 mb-8">
                <!-- Soft CTA (Google Calendar / Audit) -->
                <div class="bg-slate-50 border border-slate-200 p-8 rounded-3xl text-left flex flex-col shadow-lg">
                    <h4 class="text-xl font-bold text-brand-dark mb-2">Technical Audit</h4>
                    <p class="text-slate-600 text-sm mb-8 flex-grow">Not ready to build? Book a free 15-minute consultation to audit your current workflow and explore potential automation.</p>
                    
                    <div class="p-[2px] rounded-xl bg-gradient-to-r from-brand-teal to-brand-yellow hover:scale-105 transition-transform mt-auto shadow-md">
                        <button onclick="window.open('https://calendar.google.com/', '_blank')" class="w-full bg-white text-brand-dark py-4 rounded-[10px] font-bold uppercase text-xs tracking-widest flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[18px] text-brand-yellow">event_available</span>
                            Book a Video Call
                        </button>
                    </div>
                </div>

                <!-- Hard CTA (WhatsApp) -->
                <div class="bg-slate-50 p-8 rounded-3xl text-left shadow-lg relative overflow-hidden flex flex-col border border-slate-200">
                    <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-brand-teal to-brand-yellow"></div>
                    <h4 class="text-xl font-bold text-brand-dark mb-2">Direct Line</h4>
                    <p class="text-slate-600 text-sm mb-8 flex-grow">Ready to scale? Skip the email chains. Connect directly with our Lead Architect right now to discuss your project scope.</p>
                    
                    <div class="p-[2px] rounded-xl bg-gradient-to-r from-brand-teal to-brand-yellow hover:scale-105 transition-transform mt-auto shadow-md">
                        <button onclick="window.open('https://wa.me/256750432982?text=Hi%2C%20I%20would%20like%20to%20discuss%20a%20custom%20software%20project.', '_blank')" class="w-full bg-white text-brand-dark py-4 rounded-[10px] font-bold uppercase text-xs tracking-widest flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[18px] text-brand-teal">chat</span>
                            WhatsApp Us
